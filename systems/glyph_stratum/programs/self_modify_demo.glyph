// Self-Modifying Code Demo (AI-Native Opcodes)
// Demonstrates GLYPH_WRITE, M_STORE, GLYPH_MUTATE, SEMANTIC_MERGE

// Constants
.equ MEM_BASE, 0x1000

// Step 1: Store 42 in memory
M_STORE 0x1000, 42

// Step 2: Copy via GLYPH_WRITE (simulate M_STORE behavior)
GLYPH_WRITE 0x2000
 0x1000, 0

// Step 3: Modify via GLYPH_MUTATE
GLYPH_MUTATE 0x2000, 1
 42

// Step 4: Check results
HALT
