// Geometry OS - Is Alphanumeric
// Checks if character is letter or digit
// Args: r0=ASCII char
// Output: r1=1 (alnum), 0 (not)

:is_alnum
    MOV r3, r0
    CALL :is_digit
    LDI r2, 1
    SUB r2, r1, r2
    JZ r2, :yes
    MOV r0, r3
    CALL :is_alpha
    LDI r2, 1
    SUB r2, r1, r2
    JZ r2, :yes
    LDI r1, 0
    HALT

:yes
    LDI r1, 1
    HALT
