// Geometry OS - Count Trailing Zeros
// Counts trailing zeros after last 1
// Args: r0=value
// Output: r1=count

:ctz
    LDI r1, 0
    LDI r2, 1

:loop
    DIV r3, r0, r2
    MUL r3, r3, r2
    SUB r3, r0, r3
    JNZ r3, :done
    ADD r1, r1, 1
    MUL r2, r2, 2
    SUB r3, r2, r2
    JZ r3, :done
    LDI r2, 0
    JMP :loop

:done
    HALT
