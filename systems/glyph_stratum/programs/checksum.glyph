// Geometry OS - Simple Checksum (XOR)
// Computes XOR checksum of memory region
// Args: r0=start, r1=length
// Output: r2=checksum

:checksum
    LDI r2, 0    // checksum = 0
    LDI r3, 0    // offset = 0

:loop
    // Check: offset >= length -> done
    SUB r4, r1, r3
    JZ r4, :done
    
    // checksum ^= memory[offset]
    ADD r4, r0, r3
    LOAD r5, r4
    XOR r2, r2, r5
    
    ADD r3, r3, 1    // offset++
    JMP :loop

:done
    HALT
