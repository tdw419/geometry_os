// Geometry OS - Is Prime
// Checks if number is prime
// Args: r0=n
// Output: r1=1 (prime), 0 (not prime)

:is_prime
    LDI r1, 2
    SUB r1, r0, r1
    JLT r1, :not_prime
    
    LDI r1, 2
    LDI r2, 0

:check_loop
    DIV r3, r0, r2
    MUL r3, r3, r2
    SUB r3, r0, r3
    JZ r3, :not_prime
    
    ADD r2, r2, 1
    
    SUB r3, r2, r0
    JLT r3, :check_loop

:prime
    LDI r1, 1
    HALT

:not_prime
    LDI r1, 0
    HALT
