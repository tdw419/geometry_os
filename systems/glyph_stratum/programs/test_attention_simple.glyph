// Simple test: Attention focus skips execution in inactive regions
// This allows the VM to mark regions of "active" so the scheduler can skip them in inactive regions for performance.
// verify the attention_mask is test

// Write attention mask at address 100
M_STORE 100, 0  // Write to attention mask (0 = active, 0 = 0 for inactive region)
GLYPH_WRITE 200, 100, 0  // Copy from memory[100] to program[200]
M_JUMP 200  // Jump to the copied HALT

HALT
