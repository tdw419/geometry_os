// Geometry OS - Compare Memory
// Compares two memory regions
// Args: r0=a, r1=b, r2=length
// Output: r3=0 (equal), <0 (a<b), >0 (a>b)

:compare_mem
    LDI r3, 0

:loop
    LOAD r4, r0
    LOAD r5, r1
    SUB r6, r4, r5
    JNZ r6, :done
    ADD r0, r0, 1
    ADD r1, r1, 1
    SUB r2, r2, 1
    JNZ r2, :loop

:done
    MOV r3, r6
    HALT
