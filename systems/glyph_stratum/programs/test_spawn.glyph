// Test GLYPH_WRITE (opcode 232) for self-modifying code
// Uses glyph_vm_scheduler.wgsl opcodes (M_ prefix)

// Store HALT opcode (13) at memory address 100
// M_STORE (206): mem[dst] = immediate (stratum=dst, p1=value)
M_STORE 100, 13

// Store stratum (0) at address 101
M_STORE 101, 0

// Store p1 (0) at address 102
M_STORE 102, 0

// Store p2 (0) at address 103
M_STORE 103, 0

// GLYPH_WRITE (232): copy glyph from memory[100] to program[200]
// encoding: R=232, G=target, B=source, A=count
// stratum=target (200), p1=source (100), p2=count (0=single)
GLYPH_WRITE 200, 100, 0

// Jump to address 200 - should hit the HALT we wrote
// M_JUMP (208): pc = stratum
M_JUMP 200

// Fallback (should never reach)
HALT
