// Test SPATIAL_SPAWN (opcode 232)
// Verifies that a program can write new glyphs into itself

// Setup: Write a HALT instruction into memory at address 100-104
// Memory layout: 5 floats per glyph (opcode, stratum, p1, p2, dst)

// memory[100] = 141 (HALT opcode)
LDI r0, 141
STORE r0, 100

// memory[101] = 0 (stratum)
LDI r0, 0
STORE r0, 101

// memory[102] = 0 (p1)
STORE r0, 102

// memory[103] = 0 (p2)
STORE r0, 103

// memory[104] = 0 (dst)
STORE r0, 104

// Spawn single glyph at program[200] from memory[100]
// SPAWN dst=200, src=100, count=0 (single mode)
SPAWN 200, 100, 0

// Jump to 200 - should hit the spawned HALT
JMP 200

// Should never reach here
NOP
NOP
HALT
