// ============================================================================
// Geometry OS - Attention-Weighted Meta-Circular Scheduler (VM 0)
// ============================================================================
//
// This glyph implements attention-weighted VM scheduling inspired by LLM attention mechanisms.
// VM 0 attends to which VMs deserve compute cycles based on:
//   - Recent activity (recency bias)
//   - Historical performance (importance)
//   - Resource usage patterns
//
// Attention mechanism: Each VM gets an attention score that determines its scheduling priority.
// Higher attention = more frequent/longer time slices.
//
// Brain Bridge Memory Map (same as original scheduler):
// - 0x2000: CTRL_SEMAPHORE (1 = request pending)
// - 0x2004: RESPONSE_READY (1 = response available)
// - 0x2008: REQUEST_LENGTH (bytes)
// - 0x0500: HTTP Request Buffer start
// - 0x1000: HTTP Response Buffer start
// - 0x0300: Cognitive State (current_intent)
// - 0x0304: thought_cycle_count
// - 0x0308: last_action
// - 0x030C: fitness_score
//
// Attention-specific memory map:
// - 0x3000: Attention scores for VMs 1-255 (1 byte each, 0-255)
// - 0x3100: VM activity counters (4 bytes each)
// - 0x3200: VM importance weights (4 bytes each, fixed point)
// - 0x3300: Last schedule frame for each VM (4 bytes each)

.equ TRAP_BASE,    0xFF000000
.equ TRAP_OP,      0xFF000000
.equ TRAP_ARG0,    0xFF000004
.equ TRAP_ARG1,    0xFF000008
.equ TRAP_RESULT,  0xFF000010
.equ TRAP_STATUS,  0xFF000014

.equ VM_TABLE,     0xFE000000    // VM state table region
.equ MAX_VMS,      255
.equ BASE_CYCLES_PER_VM, 32     // Base cycles, attention modifies this

// VM state offsets (relative to VM base)
.equ VM_STATE,     0
.equ VM_PC,        4
.equ VM_ACTIVE,    1

// Brain Bridge addresses
.equ BRAIN_CTRL_SEMAPHORE, 0x2000
.equ BRAIN_RESPONSE_READY, 0x2004
.equ BRAIN_REQUEST_LENGTH, 0x2008
.equ BRAIN_REQUEST_START,  0x0500
.equ BRAIN_RESPONSE_START, 0x1000
.equ BRAIN_CURRENT_INTENT, 0x0300
.equ BRAIN_THOUGHT_COUNT,  0x0304
.equ BRAIN_LAST_ACTION,    0x0308
.equ BRAIN_FITNESS,        0x030C

// Attention memory regions
.equ ATTENTION_SCORES,   0x3000    // 1 byte per VM (1-255)
.equ VM_ACTIVITY,        0x3100    // 4 bytes per VM
.equ VM_IMPORTANCE,      0x3200    // 4 bytes per VM (fixed point)
.equ LAST_SCHEDULED,     0x3300    // 4 bytes per VM

// Brain coordination state
.equ BRAIN_POLL_INTERVAL,  100   // Poll brain every N frames
.equ BRAIN_ACTION_NONE,    0
.equ BRAIN_ACTION_REBALANCE, 1
.equ BRAIN_ACTION_SPAWN,   2
.equ BRAIN_ACTION_KILL,    3

:main
    // Mark self as running (VM 0)
    LDI r1, 0xFF000100
    LDI r2, 1           // RUNNING
    STORE r1, r2

    // Initialize frame counter
    LDI r20, 0          // r20 = frame count

    // Initialize attention system
    CALL :init_attention_system

    // Initialize brain coordination state
    LDI r23, 0          // r23 = last brain poll frame
    LDI r24, BRAIN_ACTION_NONE  // r24 = pending brain action

    // Initialize cognitive state region
    LDI r1, BRAIN_CURRENT_INTENT
    LDI r2, 0           // No initial intent
    STORE r1, r2

    LDI r1, BRAIN_THOUGHT_COUNT
    LDI r2, 0
    STORE r1, r2

    LDI r1, BRAIN_FITNESS
    LDI r2, 0x3F800000  // 1.0 as float bits
    STORE r1, r2

:scheduler_loop
    ADDI r20, r20, 1    // frame++

    // ================================================================
    // BRAIN COORDINATION: Check for AI guidance
    // ================================================================

    // Check if it's time to poll the brain
    LDI r1, BRAIN_POLL_INTERVAL
    ADD r1, r23, r1     // r1 = last_poll + interval
    SUB r1, r20         // r1 = (last_poll + interval) - frame
    LDI r2, 0
    SUB r1, r2          // If r1 <= 0, time to poll
    JNZ :skip_brain_poll

    // Time to poll brain - check for response
    LDI r1, BRAIN_RESPONSE_READY
    LOAD r1, r25        // r25 = response ready flag

    LDI r2, 1
    SUB r25, r2
    JNZ :brain_no_response

    // Response is ready - read brain's intent
    LDI r1, BRAIN_CURRENT_INTENT
    LOAD r1, r24        // r24 = brain's suggested action

    // Update thought cycle count
    LDI r1, BRAIN_THOUGHT_COUNT
    LOAD r1, r26        // r26 = current count
    ADDI r26, r26, 1    // increment
    LDI r1, BRAIN_THOUGHT_COUNT
    STORE r1, r26

    // Clear response ready flag
    LDI r1, BRAIN_RESPONSE_READY
    LDI r2, 0
    STORE r1, r2

    // Record last action
    LDI r1, BRAIN_LAST_ACTION
    STORE r1, r24

    // Update last poll frame
    LDI r23, r20
    JMP :brain_processed

:brain_no_response
    // No response yet - check if we should request one
    LDI r1, BRAIN_CTRL_SEMAPHORE
    LOAD r1, r25        // r25 = semaphore value

    LDI r2, 0
    SUB r25, r2
    JNZ :skip_brain_request  // Request already pending

    // Build simple request asking for scheduling guidance
    // Request: "Analyze VM load and suggest action"
    LDI r10, BRAIN_REQUEST_START

    // Write request message (simplified - just marker bytes)
    LDI r1, r10
    LDI r2, 0x564D5F53  // "VM_S" in ASCII
    STORE r1, r2
    ADDI r10, r10, 4

    LDI r1, r10
    LDI r2, 0x54415445  // "TATE" in ASCII
    STORE r1, r2
    ADDI r10, r10, 4

    LDI r1, r10
    LDI r2, 0x5F524551  // "_REQ" in ASCII
    STORE r1, r2
    ADDI r10, r10, 4

    // Calculate request length (12 bytes)
    LDI r1, BRAIN_REQUEST_LENGTH
    LDI r2, 12
    STORE r1, r2

    // Set semaphore to trigger brain bridge
    LDI r1, BRAIN_CTRL_SEMAPHORE
    LDI r2, 1
    STORE r1, r2

    // Update last poll frame
    LDI r23, r20

:skip_brain_request
:skip_brain_poll
:brain_processed

    // ================================================================
    // EXECUTE BRAIN ACTION (if any)
    // ================================================================

    // Check for pending brain action
    LDI r2, BRAIN_ACTION_NONE
    SUB r24, r2
    JZ :no_brain_action

    // Execute action based on r24
    LDI r2, BRAIN_ACTION_REBALANCE
    SUB r24, r2
    JNZ :check_spawn_action

    // REBALANCE: Recompute attention scores based on VM performance
    LDI r24, BRAIN_ACTION_NONE
    CALL :recompute_attention_scores
    JMP :no_brain_action

:check_spawn_action
    LDI r2, BRAIN_ACTION_SPAWN
    SUB r24, r2
    JNZ :check_kill_action

    // SPAWN: Request new VM via trap
    LDI r1, TRAP_OP
    LDI r2, 3           // SPAWN_VM op
    STORE r1, r2

    LDI r1, TRAP_ARG0
    LDI r2, 0           // entry point (placeholder - should come from brain)
    STORE r1, r2

    LDI r1, TRAP_STATUS
    LDI r2, 1           // PENDING
    STORE r1, r2

    LDI r24, BRAIN_ACTION_NONE
    JMP :no_brain_action

:check_kill_action
    LDI r2, BRAIN_ACTION_KILL
    SUB r24, r2
    JNZ :no_brain_action

    // KILL: Request VM termination via trap
    // TODO: Get VM ID from brain response (for now, kill lowest attention VM)
    LDI r1, TRAP_OP
    LDI r2, 4           // KILL_VM op
    STORE r1, r2

    // Find VM with lowest attention score to kill
    LDI r1, ATTENTION_SCORES
    LDI r2, 1           // Start with VM 1
    LDI r3, 255         // r3 = current VM ID to check
    LDI r4, 255         // r4 = min attention score found
    LDI r5, 1           // r5 = VM ID with min attention

:find_min_attention_loop
    LOAD r1, r6         // r6 = attention score of current VM
    SUB r6, r4
    JGE :not_new_min    // If attention >= current min, skip
    MOV r4, r6          // New minimum found
    MOV r5, r3          // Record VM ID

:not_new_min
    ADDI r1, r1, 1      // Next VM's attention score
    ADDI r3, r3, 1      // Next VM ID
    LDI r6, 255
    SUB r6, r3
    JNZ :find_min_attention_loop

    // Kill the VM with lowest attention
    LDI r1, TRAP_ARG0
    LDI r2, r5          // VM ID to kill
    STORE r1, r2

    LDI r24, BRAIN_ACTION_NONE
    JMP :no_brain_action

:no_brain_action

    // ================================================================
    // ATTENTION-WEIGHTED VM SCHEDULING
    // ================================================================

    // Update attention decay (older activity gets less weight)
    LDI r20, r20
    ANDI r20, r20, 31   // Only decay every 32 frames
    JNZ :skip_attention_decay
    CALL :decay_attention_scores
:skip_attention_decay

    // Select next VM based on attention weights
    CALL :select_vm_by_attention
    MOV r21, r0         // r21 = selected VM ID

    // Execute the selected VM for attention-weighted cycles
    LDI r1, VM_TABLE
    LDI r2, 256         // Each VM state is 256 bytes (simplified)
    MUL r2, r21         // Offset to VM state
    ADD r1, r2          // r1 = pointer to VM state

    // Check if VM is active
    LDI r2, 1           // Active flag offset
    ADD r1, r2
    LOAD r1, r2         // r2 = active flag
    SUB r2, 1
    JZ :scheduler_loop  // Skip inactive VMs

    // Get attention score for this VM
    LDI r1, ATTENTION_SCORES
    ADDI r1, r21        // Offset to this VM's attention score
    LOAD r1, r22        // r22 = attention score (0-255)

    // Calculate cycles: base_cycles * (attention_score / 255 + 1)
    // This gives 1x to 2x base cycles based on attention
    LDI r3, BASE_CYCLES_PER_VM
    LDI r4, 255
    MUL r3, r22         // base * attention
    DIV r3, r4          // Divide by 255
    ADD r3, r3, BASE_CYCLES_PER_VM  // Add base
    MOV r25, r3         // r25 = cycles to execute

    // Execute VM for calculated cycles
    LDI r26, 0          // cycle counter

:vm_execution_loop
    // Execute one instruction via trap
    LDI r1, TRAP_OP
    LDI r2, 1           // EXECUTE_INSTRUCTION op
    STORE r1, r2

    LDI r1, TRAP_ARG0
    LDI r2, r21         // VM ID to execute
    STORE r1, r2

    LDI r1, TRAP_STATUS
    LDI r2, 1           // PENDING
    STORE r1, r2

    // Check if VM halted
    LDI r1, TRAP_RESULT
    LOAD r1, r2         // r2 = halt status (0=running, 1=halted)
    LDI r3, 1
    SUB r2, r3
    JNZ :vm_execution_done

    // Increment cycle counter
    ADDI r26, r26, 1
    LDI r3, 0
    SUB r26, r25        // Check if we've done enough cycles
    JNZ :vm_execution_loop

:vm_execution_done
    // Update last scheduled time
    LDI r1, LAST_SCHEDULED
    ADDI r1, r21, 2     // Offset to last_scheduled (assuming 2-byte offset for simplicity)
    LDI r2, r20         // Current frame
    STORE r1, r2

    // Update activity counter for this VM
    LDI r1, VM_ACTIVITY
    ADDI r1, r21, 4     // 4 bytes per VM
    LOAD r1, r2         // Load current activity
    ADDI r2, r2, 1      // Increment
    LDI r1, VM_ACTIVITY
    ADDI r1, r21, 4
    STORE r1, r2

    JMP :scheduler_loop

// ============================================================================
// SUBROUTINES
// ============================================================================

:init_attention_system
    // Initialize attention scores to default (128 = medium)
    LDI r1, ATTENTION_SCORES
    LDI r2, 1           // Start with VM 1
    LDI r3, 128         // Default attention score

:init_attention_loop
    STORE r1, r3
    ADDI r1, r1, 1
    ADDI r2, r2, 1
    LDI r4, 255
    SUB r4, r2
    JNZ :init_attention_loop

    // Initialize activity counters to 0
    LDI r1, VM_ACTIVITY
    LDI r2, 1
    LDI r3, 0

:init_activity_loop
    STORE r1, r3
    STORE r1, r3        // Second byte
    STORE r1, r3        // Third byte
    STORE r1, r3        // Fourth byte
    ADDI r1, r1, 4
    ADDI r2, r2, 1
    LDI r4, 255
    SUB r4, r2
    JNZ :init_activity_loop

    // Initialize importance weights to 1.0 (fixed point: 1.0 = 0x3F800000)
    LDI r1, VM_IMPORTANCE
    LDI r2, 1
    LDI r3, 0x3F800000

:init_importance_loop
    STORE r1, r3        // First byte
    STORE r1, r3        // Second byte
    STORE r1, r3        // Third byte
    STORE r1, r3        // Fourth byte
    ADDI r1, r1, 4
    ADDI r2, r2, 1
    LDI r4, 255
    SUB r4, r2
    JNZ :init_importance_loop

    // Initialize last scheduled to 0
    LDI r1, LAST_SCHEDULED
    LDI r2, 1
    LDI r3, 0

:init_last_scheduled_loop
    STORE r1, r3
    STORE r1, r3
    STORE r1, r3
    STORE r1, r3
    ADDI r1, r1, 4
    ADDI r2, r2, 1
    LDI r4, 255
    SUB r4, r2
    JNZ :init_last_scheduled_loop

    RET

:decay_attention_scores
    // Apply decay to all attention scores (multiply by 0.95)
    LDI r1, ATTENTION_SCORES
    LDI r2, 1           // Start with VM 1

:decay_loop
    LOAD r1, r3         // Load current attention score
    // r3 = r3 * 0.95 (approx: r3 - r3/20)
    LDI r4, r3
    LDI r5, 20
    DIV r4, r5          // r4 = r3 / 20
    SUB r3, r4          // r3 = r3 - r3/20
    // Ensure minimum of 1
    LDI r4, 1
    SUB r3, r4
    JGE :no_underflow
    LDI r3, 1

:no_underflow
    STORE r1, r3
    ADDI r1, r1, 1
    ADDI r2, r2, 1
    LDI r4, 255
    SUB r4, r2
    JNZ :decay_loop

    RET

:recompute_attention_scores
    // Recompute attention scores based on activity and importance
    // attention = log(1 + activity) * importance
    LDI r1, VM_ACTIVITY
    LDI r2, ATTENTION_SCORES
    LDI r3, VM_IMPORTANCE
    LDI r4, 1           // Start with VM 1

:recompute_loop
    // Load activity (4 bytes)
    LDI r5, r1
    LOAD r5, r6         // r6 = activity byte 0
    ADDI r5, r5, 1
    LOAD r5, r7         // r7 = activity byte 1
    ADDI r5, r5, 1
    LOAD r5, r8         // r8 = activity byte 2
    ADDI r5, r5, 1
    LOAD r5, r9         // r9 = activity byte 3
    // Combine bytes into activity value (simplified - just use first byte for now)
    MOV r6, r6          // Use first byte as activity for simplicity

    // Load importance (4 bytes)
    LDI r5, r3
    LOAD r5, r10        // r10 = importance byte 0
    // Simplified: use first byte as importance

    // Calculate attention: log(1 + activity) * importance
    // Approximate log(1+x) for small x: x/(1+x/2)
    LDI r5, r6          // activity
    LDI r7, 2
    MUL r7, r6
    ADD r7, r7, 1       // denominator: 1 + activity/2
    DIV r6, r7          // r6 = activity / (1 + activity/2) ≈ log(1+activity)
    MUL r6, r10         // Multiply by importance

    // Store attention score (clamp to 1-255)
    LDI r7, 1
    SUB r6, r7
    JGE :attention_ok
    LDI r6, 1

:attention_ok
    LDI r7, 255
    SUB r6, r7
    JLE :attention_ok2
    LDI r6, 255

:attention_ok2
    STORE r2, r6

    // Move to next VM
    ADDI r1, r1, 4      // Next activity
    ADDI r2, r2, 1      // Next attention score
    ADDI r3, r3, 4      // Next importance
    ADDI r4, r4, 1
    LDI r5, 255
    SUB r5, r4
    JNZ :recompute_loop

    RET

:select_vm_by_attention
    // Select VM using attention-weighted random selection
    // Build cumulative distribution and pick random point
    LDI r1, ATTENTION_SCORES
    LDI r2, 1           // Start with VM 1
    LDI r3, 0           // r3 = cumulative sum
    LDI r4, 0           // r4 = selected VM ID

    // First pass: calculate total attention
    LDI r5, 0           // r5 = total attention

:sum_loop
    LOAD r1, r6         // Load attention score
    ADD r5, r5, r6
    ADDI r1, r1, 1
    ADDI r2, r2, 1
    LDI r7, 255
    SUB r7, r2
    JNZ :sum_loop

    // If total attention is 0, select VM 1
    LDI r6, 0
    SUB r5, r6
    JZ :select_vm_1

    // Generate random number [0, total_attention)
    // Simple pseudo-random: use frame counter
    LDI r6, r20         // Use frame counter as random seed
    LDI r7, 17          // Prime multiplier
    MUL r6, r6, r7
    LDI r7, 31          // Another prime
    ADD r6, r6, r7
    DIV r6, r5          // r6 = random % total_attention

    // Second pass: find VM where cumulative sum > random
    LDI r1, ATTENTION_SCORES
    LDI r2, 1
    LDI r3, 0           // cumulative sum

:selection_loop
    LOAD r1, r4         // Load attention score
    ADD r3, r3, r4      // Add to cumulative
    SUB r3, r6          // Subtract random target
    JGE :selected       // If cumulative >= random, we've selected
    ADDI r1, r1, 1
    ADDI r2, r2, 1
    LDI r5, 255
    SUB r5, r2
    JNZ :selection_loop

    // Fallback to VM 1
    LDI r2, 1
    JMP :return_selected

:selected
    MOV r4, r2          // Store selected VM ID

:return_selected
    MOV r0, r4          // Return selected VM ID in r0
    RET

:select_vm_1
    LDI r2, 1
    MOV r0, r2
    RET