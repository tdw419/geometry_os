// ============================================================================
// FACTORIAL TEST - Glyph Program for Benchmarking
// ============================================================================
//
// Computes factorial(3) = 6
// Register usage:
//   r0 = 0 (zero register)
//   r1 = result (accumulator)
//   r2 = counter
//   r3 = constant 1
//   r4 = temp
//
// Memory layout (for constants):
//   0x0000 = 1 (constant ONE)
//   0x0001 = 3 (initial counter value)
//
// Entry point: 0x0000
// Stratum: LOGIC (2)
// ============================================================================

.equ OP_NOP, 0
.equ OP_ALLOC, 1
.equ OP_FREE, 2
.equ OP_LOAD, 3
.equ OP_STORE, 4
.equ OP_ADD, 5
.equ OP_SUB, 6
.equ OP_MUL, 7
.equ OP_DIV, 8
.equ OP_JMP, 9
.equ OP_BRANCH, 10
.equ OP_CALL, 11
.equ OP_RETURN, 12
.equ OP_HALT, 13
.equ OP_DATA, 14
.equ OP_LOOP, 15

.equ CONST_ONE_ADDR, 0x0000
.equ INIT_COUNTER_ADDR, 0x0001
.equ RESULT_ADDR, 0x0002
.equ COUNTER_ADDR, 0x0003

// Entry point - initialize memory with constants
0x0000: // Store constant 1 at CONST_ONE_ADDR
        OP_DATA, 0, 1, 0          // r0 = 1
        OP_STORE, 0, CONST_ONE_ADDR, 0  // *CONST_ONE_ADDR = r0

        // Store initial counter value (3) at INIT_COUNTER_ADDR
        OP_DATA, 0, 3, 0          // r0 = 3
        OP_STORE, 0, INIT_COUNTER_ADDR, 0  // *INIT_COUNTER_ADDR = r0

        // Initialize result register r1 = 1
        OP_LOAD, 1, CONST_ONE_ADDR, 0   // r1 = *CONST_ONE_ADDR

        // Initialize counter register r2 = 3
        OP_LOAD, 2, INIT_COUNTER_ADDR, 0  // r2 = *INIT_COUNTER_ADDR

        // Initialize constant register r3 = 1
        OP_LOAD, 3, CONST_ONE_ADDR, 0   // r3 = *CONST_ONE_ADDR

        // Start of loop
0x0010: // Check if counter == 0
        OP_DATA, 0, 2, 0          // r0 = r2 (copy counter)
        OP_SUB, 0, 0, 3, 0        // r3 = r0 - r3 (r3 = counter - 1, but we want to compare to 0)
        // Actually, let's just do: if r2 == 0 then exit
        // We can use OP_BRANCH which branches if reg[p1] == 0
        OP_BRANCH, 2, 0x0028, 0   // if r2 == 0 jump to 0x0028 (end)

        // Loop body: result = result * counter
        OP_MUL, 1, 1, 2, 0        // r2 = r1 * r2 (WARNING: this modifies r2!)
        // We need to be careful about register usage
        // Let's use different approach: store result in r1, counter in r2
        // To compute r1 = r1 * r2:
        // We can do: r0 = r1 * r2, then r1 = r0
        OP_MUL, 0, 1, 2, 0        // r0 = r1 * r2
        OP_DATA, 1, 0, 0, 0       // r1 = r0

        // Loop body: counter = counter - 1
        OP_SUB, 2, 2, 3, 0        // r2 = r2 - r3

        OP_DATA, 0, 0x0010, 0, 0  // r0 = loop start address
        OP_JMP, 0, 0, 0, 0        // jump to loop start

// End: store result and halt
0x0028: OP_STORE, 1, RESULT_ADDR, 0   // *RESULT_ADDR = r1
        OP_HALT, 0, 0, 0, 0       // halt

// ============================================================================
// Constant data (pre-initialized memory)
// ============================================================================
0x0100: 0x00000001  // CONST_ONE_ADDR = 1
0x0104: 0x00000003  // INIT_COUNTER_ADDR = 3
0x0108: 0x00000000  // RESULT_ADDR = 0 (will be set to 6)
0x010C: 0x00000000  // COUNTER_ADDR = 0 (will be set to 3)