{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "GlyphStratum",
  "scopeName": "source.glyph",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strata"
    },
    {
      "include": "#opcodes"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#keys"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.glyph",
          "match": "//.*$"
        },
        {
          "name": "comment.block.glyph",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strata": {
      "patterns": [
        {
          "name": "constant.language.stratum.substrate.glyph",
          "match": "\\bSUBSTRATE\\b"
        },
        {
          "name": "constant.language.stratum.memory.glyph",
          "match": "\\bMEMORY\\b"
        },
        {
          "name": "constant.language.stratum.logic.glyph",
          "match": "\\bLOGIC\\b"
        },
        {
          "name": "constant.language.stratum.spec.glyph",
          "match": "\\bSPEC\\b"
        },
        {
          "name": "constant.language.stratum.intent.glyph",
          "match": "\\bINTENT\\b"
        }
      ]
    },
    "opcodes": {
      "patterns": [
        {
          "name": "keyword.control.opcode.core.glyph",
          "match": "\\b(NOP|DATA|LOAD|STORE|ALLOC|FREE|CALL|BRANCH|LOOP|RETURN|EXPORT|MODULE|HALT)\\b"
        },
        {
          "name": "keyword.operator.opcode.math.glyph",
          "match": "\\b(MATH|ADD|SUB|MUL|DIV|MOD|NEG|ABS)\\b"
        },
        {
          "name": "keyword.operator.opcode.compare.glyph",
          "match": "\\b(COMPARE|EQ|NE|LT|LE|GT|GE)\\b"
        },
        {
          "name": "keyword.other.opcode.string.glyph",
          "match": "\\b(STRING|CONCAT|LEN|SUBSTR)\\b"
        },
        {
          "name": "keyword.other.opcode.array.glyph",
          "match": "\\b(ARRAY|PUSH|POP|ARRAYLEN|GET|SET)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.glyph",
          "match": "\\b-?[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.glyph",
          "match": "\\b-?[0-9]+\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.glyph",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.glyph",
          "match": "\\\\."
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.glyph",
          "match": "\\btrue\\b"
        },
        {
          "name": "constant.language.boolean.false.glyph",
          "match": "\\bfalse\\b"
        }
      ]
    },
    "keys": {
      "patterns": [
        {
          "name": "entity.name.tag.glyph",
          "match": "\"(stratum|opcode|dependencies|invariants|value|type)\"\\s*:"
        },
        {
          "name": "variable.other.glyph",
          "match": "\"[a-zA-Z_][a-zA-Z0-9_]*\"\\s*:"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "punctuation.separator.glyph",
          "match": ":"
        },
        {
          "name": "punctuation.separator.comma.glyph",
          "match": ","
        },
        {
          "name": "meta.brace.square.glyph",
          "match": "[\\[\\]]"
        },
        {
          "name": "meta.brace.curly.glyph",
          "match": "[\\{\\}]"
        }
      ]
    }
  }
}
