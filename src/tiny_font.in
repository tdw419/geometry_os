  [0x04, 0x02, 0x03, 0x02, 0x04], // {
  [0x02, 0x02, 0x02, 0x02, 0x02], // |
  [0x01, 0x02, 0x06, 0x02, 0x01], // }
  [0x06, 0x03, 0x00, 0x00, 0x00], // ~
  [0x00, 0x00, 0x00, 0x00, 0x00], // DEL (blank)
]
