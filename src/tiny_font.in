// tiny_font.in -- 3x5 bitmap font for SMALLTEXT opcode (terminal-optimized)
// 96 glyphs (ASCII 0x20-0x7F), each 5 rows of 3-bit wide bitmaps
// Bit test: glyph[row] & (1 << (2 - col))
// Advance: 3 pixels per character (no spacing) -> 85 columns in 256px
[
  [0x00, 0x00, 0x00, 0x00, 0x00], // space
  [0x02, 0x02, 0x02, 0x00, 0x02], // !
  [0x05, 0x05, 0x00, 0x00, 0x00], // "
  [0x05, 0x07, 0x05, 0x07, 0x05], // #
  [0x06, 0x01, 0x07, 0x04, 0x03], // $
  [0x05, 0x02, 0x04, 0x01, 0x05], // %
  [0x02, 0x05, 0x03, 0x05, 0x06], // &
  [0x02, 0x04, 0x00, 0x00, 0x00], // '
  [0x04, 0x02, 0x02, 0x02, 0x04], // (
  [0x01, 0x02, 0x02, 0x02, 0x01], // )
  [0x05, 0x02, 0x07, 0x02, 0x05], // *
  [0x00, 0x02, 0x07, 0x02, 0x00], // +
  [0x00, 0x00, 0x00, 0x02, 0x04], // ,
  [0x00, 0x00, 0x07, 0x00, 0x00], // -
  [0x00, 0x00, 0x00, 0x00, 0x02], // .
  [0x04, 0x04, 0x02, 0x02, 0x01], // /
  [0x03, 0x05, 0x05, 0x05, 0x03], // 0
  [0x02, 0x06, 0x02, 0x02, 0x07], // 1
  [0x03, 0x04, 0x03, 0x01, 0x07], // 2
  [0x07, 0x04, 0x03, 0x04, 0x03], // 3
  [0x05, 0x05, 0x07, 0x04, 0x04], // 4
  [0x07, 0x01, 0x07, 0x04, 0x03], // 5
  [0x03, 0x01, 0x07, 0x05, 0x03], // 6
  [0x07, 0x04, 0x04, 0x02, 0x02], // 7
  [0x03, 0x05, 0x03, 0x05, 0x03], // 8
  [0x03, 0x05, 0x07, 0x04, 0x03], // 9
  [0x00, 0x02, 0x00, 0x02, 0x00], // :
  [0x00, 0x02, 0x00, 0x02, 0x04], // ;
  [0x04, 0x02, 0x01, 0x02, 0x04], // <
  [0x00, 0x07, 0x00, 0x07, 0x00], // =
  [0x01, 0x02, 0x04, 0x02, 0x01], // >
  [0x03, 0x04, 0x02, 0x00, 0x02], // ?
  [0x03, 0x05, 0x07, 0x01, 0x06], // @
  [0x02, 0x05, 0x07, 0x05, 0x05], // A
  [0x07, 0x05, 0x07, 0x05, 0x07], // B
  [0x03, 0x04, 0x04, 0x04, 0x03], // C
  [0x07, 0x05, 0x05, 0x05, 0x07], // D (was 0x06, 0x05)
  [0x07, 0x01, 0x07, 0x01, 0x07], // E
  [0x07, 0x01, 0x07, 0x01, 0x01], // F
  [0x03, 0x04, 0x05, 0x05, 0x07], // G
  [0x05, 0x05, 0x07, 0x05, 0x05], // H
