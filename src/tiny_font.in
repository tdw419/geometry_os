  [0x01, 0x01, 0x03, 0x05, 0x07], // b
  [0x00, 0x00, 0x03, 0x01, 0x03], // c
  [0x04, 0x04, 0x06, 0x05, 0x06], // d
  [0x00, 0x03, 0x05, 0x07, 0x03], // e
  [0x03, 0x05, 0x07, 0x01, 0x03], // f (was wrong)
  [0x06, 0x05, 0x07, 0x04, 0x03], // g
  [0x01, 0x01, 0x03, 0x05, 0x05], // h
  [0x02, 0x00, 0x02, 0x02, 0x07], // i
  [0x04, 0x00, 0x04, 0x04, 0x05], // j
  [0x01, 0x05, 0x03, 0x05, 0x05], // k
  [0x02, 0x02, 0x02, 0x02, 0x07], // l
  [0x00, 0x07, 0x07, 0x05, 0x05], // m
  [0x00, 0x03, 0x05, 0x05, 0x05], // n
  [0x00, 0x02, 0x05, 0x05, 0x02], // o
  [0x07, 0x05, 0x07, 0x01, 0x01], // p
  [0x06, 0x05, 0x07, 0x04, 0x04], // q
  [0x00, 0x01, 0x03, 0x05, 0x05], // r
