  [0x05, 0x07, 0x07, 0x07, 0x05], // N
  [0x03, 0x05, 0x05, 0x05, 0x03], // O
  [0x07, 0x05, 0x07, 0x01, 0x01], // P
  [0x03, 0x05, 0x05, 0x07, 0x06], // Q
  [0x07, 0x05, 0x07, 0x03, 0x05], // R
  [0x03, 0x01, 0x03, 0x04, 0x03], // S
  [0x07, 0x02, 0x02, 0x02, 0x02], // T
  [0x05, 0x05, 0x05, 0x05, 0x03], // U
