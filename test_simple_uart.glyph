// Simple UART test - directly write "GEOM" to UART
// No RISC-V emulation, just glyph instructions storing to memory

.equ UART, 0x200

:boot
    // r12 = 1 (for incrementing)
    LDI r12, 1

    // Store 'G' (71) at UART[0]
    LDI r10, UART
    LDI r11, 71
    STORE r10, r11

    // Store 'E' (69) at UART[1]
    ADD r12, r10
    LDI r11, 69
    STORE r10, r11

    // Store 'O' (79) at UART[2]
    ADD r12, r10
    LDI r11, 79
    STORE r10, r11

    // Store 'M' (77) at UART[3]
    ADD r12, r10
    LDI r11, 77
    STORE r10, r11

    // Halt
    HALT
