// ============================================================================
// Geometry OS - RISC-V Emulator - Step 1: Test ADD
// ============================================================================

:boot
    // Just ADD 1 + 1 = 2
    LDI r15, 1   // r15 = 1
    LDI r16, 1   // r16 = 1
    ADD r15, r16 // r15 = r15 + r16 = 2

    // Output result
    LDI r16, 0x0200
    STORE r16, r15

    HALT
