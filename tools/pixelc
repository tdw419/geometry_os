#!/usr/bin/env python3
"""
pixelc -- Pixel Compiler for Geometry OS
=========================================

Compiles a familiar Python-like syntax into .gasm assembly.

    familiar code (keystrokes) -> pixelc -> .gasm -> assembler -> pixels -> VM

Usage:
    pixelc program.gp                    # emit .gasm to stdout
    pixelc program.gp -o program.asm     # write .gasm to file

Syntax (.gp files):
    x = 42               ->  LDI rN, 42
    y = x + 8            ->  LDI scratch, 8; ADD rX, scratch
    ram[addr] = val      ->  STORE addrReg, valReg
    v = ram[addr]        ->  LOAD dstReg, addrReg
    pixel(x, y, color)   ->  PSET
    rect(x, y, w, h)     ->  RECTF
    circle(cx, cy, r)    ->  CIRCLEF
    line(x1,y1,x2,y2)    ->  LINE
    if x > 5:            ->  conditional branch
    while x > 0:         ->  loop
    fn name(args):        ->  function definition
    halt() / yield()     ->  HALT / YIELD

Registers r0-r27 for variables, r28-r30 scratch, r31=zero.
"""

import sys
import re
import argparse
from dataclasses import dataclass


# ═══════════════════════════════════════════════════════════════
# INDENTATION-AWARE LINE SPLITTING
# ═══════════════════════════════════════════════════════════════

class Line:
    __slots__ = ('text', 'indent', 'number')
    def __init__(self, text, indent, number):
        self.text = text
        self.indent = indent
        self.number = number
    def __repr__(self):
        return f"L{self.number}({self.indent}): {self.text!r}"

def split_lines(source):
    """Split source into Lines with indent levels."""
    lines = []
    for i, raw in enumerate(source.split('\n'), 1):
        stripped = raw.lstrip()
        if not stripped or stripped.startswith('#'):
            continue
        indent = len(raw) - len(stripped)
        lines.append(Line(stripped.rstrip(), indent, i))
    return lines


# ═══════════════════════════════════════════════════════════════
# AST NODES
# ═══════════════════════════════════════════════════════════════

@dataclass
class VarAssign:
    name: str; value: object
@dataclass
class VarModify:
    name: str; op: str; value: object
@dataclass
class MemStore:
    addr: object; value: object
@dataclass
class IfStmt:
    cond: object; body: list; else_body: list
@dataclass
class WhileStmt:
    cond: object; body: list
@dataclass
class FnDef:
    name: str; params: list; body: list
@dataclass
class ReturnStmt:
    value: object
@dataclass
class ExprStmt:
    expr: object
@dataclass
class BinOp:
    left: object; op: str; right: object
@dataclass
class UnOp:
    op: str; right: object
@dataclass
class Var:
    name: str
@dataclass
class Num:
    value: int
@dataclass
class Call:
    name: str; args: list
@dataclass
class IndexExpr:
    obj: str; index: object
@dataclass
class CondExpr:
    left: object; op: str; right: object


# ═══════════════════════════════════════════════════════════════
# EXPRESSION PARSER (recursive descent on a single line)
# ═══════════════════════════════════════════════════════════════

class ExprParser:
    """Parses a single expression string into an AST node."""

    def __init__(self, text, lineno=0):
        self.text = text
        self.pos = 0
        self.lineno = lineno

    def peek_char(self):
        if self.pos < len(self.text):
            return self.text[self.pos]
        return None

    def skip_ws(self):
        while self.pos < len(self.text) and self.text[self.pos] in ' \t':
            self.pos += 1

    def match_str(self, s):
        self.skip_ws()
        if self.text[self.pos:self.pos+len(s)] == s:
            # Make sure we don't match partial identifiers
            if s.isalpha() or s[0].isalpha():
                after = self.pos + len(s)
                if after < len(self.text) and (self.text[after].isalnum() or self.text[after] == '_'):
                    return False
            self.pos += len(s)
            return True
        return False

    def at_end(self):
        self.skip_ws()
        return self.pos >= len(self.text)

    def parse_expr(self):
        return self.parse_add()

    def parse_add(self):
        left = self.parse_mul()
        while True:
            self.skip_ws()
            if self.pos < len(self.text) and self.text[self.pos] in '+-':
                op = self.text[self.pos]
                self.pos += 1
                right = self.parse_mul()
                left = BinOp(left, op, right)
            else:
                break
        return left

    def parse_mul(self):
        left = self.parse_shift()
        while True:
            self.skip_ws()
            if self.pos < len(self.text) and self.text[self.pos] in '*/%':
                op = self.text[self.pos]
                self.pos += 1
                right = self.parse_shift()
                left = BinOp(left, op, right)
            else:
                break
        return left

    def parse_shift(self):
        left = self.parse_bitwise()
        while True:
            self.skip_ws()
            if self.text[self.pos:self.pos+2] in ('<<', '>>'):
                op = self.text[self.pos:self.pos+2]
                self.pos += 2
                right = self.parse_bitwise()
                left = BinOp(left, op, right)
            else:
                break
        return left

    def parse_bitwise(self):
        left = self.parse_unary()
        while True:
            self.skip_ws()
            if self.pos < len(self.text) and self.text[self.pos] in '&|^':
                op = self.text[self.pos]
                self.pos += 1
                right = self.parse_unary()
                left = BinOp(left, op, right)
            else:
                break
        return left

    def parse_unary(self):
        self.skip_ws()
        if self.pos < len(self.text) and self.text[self.pos] in '-~':
            op = self.text[self.pos]
            self.pos += 1
            right = self.parse_unary()
            return UnOp(op, right)
        return self.parse_primary()

    def parse_primary(self):
        self.skip_ws()
        ch = self.peek_char()
        if ch is None:
            raise SyntaxError(f"Unexpected end of expression at line {self.lineno}")

        # Number
        if ch.isdigit():
            return self._parse_number()

        # Parenthesized expression
        if ch == '(':
            self.pos += 1
            expr = self.parse_expr()
            self.skip_ws()
            if self.pos < len(self.text) and self.text[self.pos] == ')':
                self.pos += 1
            return expr

        # Identifier or keyword
        if ch.isalpha() or ch == '_':
            name = self._parse_ident()
            self.skip_ws()

            # ram[expr]
            if name == 'ram' and self.pos < len(self.text) and self.text[self.pos] == '[':
                self.pos += 1  # [
                idx = self.parse_expr()
                self.skip_ws()
                if self.pos < len(self.text) and self.text[self.pos] == ']':
                    self.pos += 1
                return IndexExpr('ram', idx)

            # Function call
            if self.pos < len(self.text) and self.text[self.pos] == '(':
                self.pos += 1
                args = []
                self.skip_ws()
                if self.pos < len(self.text) and self.text[self.pos] != ')':
                    args.append(self.parse_expr())
                    while True:
                        self.skip_ws()
                        if self.pos < len(self.text) and self.text[self.pos] == ',':
                            self.pos += 1
                            args.append(self.parse_expr())
                        else:
                            break
                self.skip_ws()
                if self.pos < len(self.text) and self.text[self.pos] == ')':
                    self.pos += 1
                return Call(name, args)

            return Var(name)

        raise SyntaxError(f"Unexpected {ch!r} in expression at line {self.lineno}")

    def _parse_number(self):
        start = self.pos
        if self.text[self.pos:self.pos+2] in ('0x', '0X'):
            self.pos += 2
            while self.pos < len(self.text) and self.text[self.pos] in '0123456789abcdefABCDEF':
                self.pos += 1
            return Num(int(self.text[start:self.pos], 16))
        while self.pos < len(self.text) and self.text[self.pos].isdigit():
            self.pos += 1
        return Num(int(self.text[start:self.pos]))

    def _parse_ident(self):
        start = self.pos
        while self.pos < len(self.text) and (self.text[self.pos].isalnum() or self.text[self.pos] == '_'):
            self.pos += 1
        return self.text[start:self.pos]


# ═══════════════════════════════════════════════════════════════
# LINE-BASED PARSER (understands indentation)
# ═══════════════════════════════════════════════════════════════

def parse(source):
    lines = split_lines(source)
    stmts, _ = parse_block(lines, 0, 0, -1)
    return stmts

def parse_block(lines, start, min_indent, stop_indent):
    """Parse statements from lines[start:] with indent >= min_indent.
    stop_indent: if >= 0, stop when we see a line at this indent (for else).
    Returns (stmts, next_pos).
    """
    stmts = []
    pos = start
    while pos < len(lines):
        line = lines[pos]
        if line.indent < min_indent:
            break
        if stop_indent >= 0 and line.indent == stop_indent:
            break

        text = line.text
        num = line.number

        if text.startswith('fn '):
            stmt, pos = parse_fndef(lines, pos)
            stmts.append(stmt)
        elif text.startswith('return'):
            ep = ExprParser(text[6:].strip(), num)
            val = None if ep.at_end() else ep.parse_expr()
            stmts.append(ReturnStmt(val))
            pos += 1
        elif text.startswith('if '):
            stmt, pos = parse_if(lines, pos)
            stmts.append(stmt)
        elif text.startswith('while '):
            stmt, pos = parse_while(lines, pos)
            stmts.append(stmt)
        else:
            stmt = parse_simple_stmt(text, num)
            stmts.append(stmt)
            pos += 1

    return stmts, pos

def parse_fndef(lines, pos):
    line = lines[pos]
    text = line.text
    num = line.number
    # fn name(params):
    m = re.match(r'fn\s+(\w+)\s*\(([^)]*)\)\s*:', text)
    if not m:
        raise SyntaxError(f"Bad fn definition at line {num}: {text}")
    name = m.group(1)
    params_str = m.group(2).strip()
    params = [p.strip() for p in params_str.split(',') if p.strip()] if params_str else []
    body_indent = lines[pos+1].indent if pos+1 < len(lines) else line.indent + 4
    body, next_pos = parse_block(lines, pos+1, body_indent, -1)
    return FnDef(name, params, body), next_pos

def parse_if(lines, pos):
    line = lines[pos]
    num = line.number
    # if cond:
    m = re.match(r'if\s+(.+):', line.text)
    if not m:
        raise SyntaxError(f"Bad if at line {num}: {line.text}")
    cond = parse_cond(m.group(1), num)
    body_indent = lines[pos+1].indent if pos+1 < len(lines) else line.indent + 4
    body, pos2 = parse_block(lines, pos+1, body_indent, -1)

    else_body = []
    if pos2 < len(lines) and lines[pos2].text.startswith('else'):
        if lines[pos2].text.startswith('else if '):
            # elif -> nested if
            sub_stmts, pos3 = parse_if(lines, pos2)
            # Rewrite the "else if" line
            else_body = [sub_stmts]
            pos2 = pos3
        elif lines[pos2].text.strip() == 'else:':
            body_indent2 = lines[pos2+1].indent if pos2+1 < len(lines) else body_indent
            else_body, pos2 = parse_block(lines, pos2+1, body_indent2, -1)

    return IfStmt(cond, body, else_body), pos2

def parse_while(lines, pos):
    line = lines[pos]
    num = line.number
    m = re.match(r'while\s+(.+):', line.text)
    if not m:
        raise SyntaxError(f"Bad while at line {num}: {line.text}")
    cond = parse_cond(m.group(1), num)
    body_indent = lines[pos+1].indent if pos+1 < len(lines) else line.indent + 4
    body, next_pos = parse_block(lines, pos+1, body_indent, -1)
    return WhileStmt(cond, body), next_pos

def parse_cond(text, lineno):
    """Parse a condition like 'x > 5' or 'x == 0'."""
    # Try to split on comparison operators (longest first)
    for op in ('==', '!=', '<=', '>=', '<', '>'):
        idx = text.find(op)
        if idx >= 0:
            left_text = text[:idx].strip()
            right_text = text[idx+len(op):].strip()
            left = ExprParser(left_text, lineno).parse_expr()
            right = ExprParser(right_text, lineno).parse_expr()
            return CondExpr(left, op, right)
    # Truthy: treat as != 0
    left = ExprParser(text.strip(), lineno).parse_expr()
    return CondExpr(left, '!=', Num(0))

def parse_simple_stmt(text, lineno):
    """Parse a single-line statement (assignment, mem store, or expr)."""

    # ram[expr] = expr
    if text.startswith('ram['):
        bracket_end = text.index(']')
        addr_text = text[4:bracket_end]
        rest = text[bracket_end+1:].strip()
        if rest.startswith('=') and not rest.startswith('=='):
            val_text = rest[1:].strip()
            addr = ExprParser(addr_text, lineno).parse_expr()
            val = ExprParser(val_text, lineno).parse_expr()
            return MemStore(addr, val)

    # name op= expr  (must check before plain =)
    m = re.match(r'(\w+)\s*(\+=|-=|\*=|/=|%=|&=|\|=|\^=|<<=|>>=)\s*(.+)', text)
    if m:
        name, op, val_text = m.group(1), m.group(2), m.group(3)
        val = ExprParser(val_text, lineno).parse_expr()
        return VarModify(name, op, val)

    # name = expr
    m = re.match(r'(\w+)\s*=\s*(.+)', text)
    if m:
        name, val_text = m.group(1), m.group(2)
        val = ExprParser(val_text, lineno).parse_expr()
        return VarAssign(name, val)

    # Expression statement
    expr = ExprParser(text, lineno).parse_expr()
    return ExprStmt(expr)


# ═══════════════════════════════════════════════════════════════
# CODE GENERATOR
# ═══════════════════════════════════════════════════════════════

class CodeGen:
    """Generates .gasm from AST.

    Registers:
      r0-r27:  variable registers (allocated on first use)
      r28-r30: scratch (temporaries for expressions)
      r31:     always zero
    """

    SCRATCH_BASE = 28  # first scratch register (r28, r29, r30)

    def __init__(self):
        self.output = []
        self.var_reg = {}
        self.next_var = 0
        self.label_id = 0
        self.fn_labels = {}
        self._scratch_depth = 0  # scratch allocation stack

    def lbl(self, hint="L"):
        self.label_id += 1
        return f"{hint}_{self.label_id}"

    def r(self, idx):
        return f"r{idx}"

    def alloc(self, name):
        if name in self.var_reg:
            return self.var_reg[name]
        if self.next_var >= self.SCRATCH_BASE:
            raise RuntimeError(f"Out of registers. Vars: {list(self.var_reg.keys())}")
        reg = self.next_var
        self.next_var += 1
        self.var_reg[name] = reg
        return reg

    def var(self, name):
        if name not in self.var_reg:
            return self.alloc(name)
        return self.var_reg[name]

    def emit(self, s):
        self.output.append(s)

    def comment(self, s):
        self.emit(f"; {s}")

    def label(self, name):
        self.emit(f"{name}:")

    def zero(self):
        self.emit(f"LDI {self.r(31)}, 0")

    def scratch_push(self):
        """Allocate a scratch register, returns its index."""
        s = self.SCRATCH_BASE + self._scratch_depth
        if s >= 31:
            raise RuntimeError("Out of scratch registers (max r30)")
        self._scratch_depth += 1
        return s

    def scratch_pop(self, n=1):
        """Free n scratch registers."""
        self._scratch_depth = max(0, self._scratch_depth - n)

    @property
    def S(self):
        """Current top scratch register (for quick access)."""
        return self.SCRATCH_BASE + self._scratch_depth

    # ── Top level ──

    def generate(self, stmts):
        self.comment("Generated by pixelc")
        self.emit("")

        # Collect functions
        fns = [s for s in stmts if isinstance(s, FnDef)]
        main = [s for s in stmts if not isinstance(s, FnDef)]

        for fn in fns:
            lbl = f"fn_{fn.name}"
            self.fn_labels[fn.name] = lbl
            self.label(lbl)
            self.comment(f"fn {fn.name}({', '.join(fn.params)})")
            for i, p in enumerate(fn.params):
                pr = self.alloc(p)
                if pr != i:
                    self.emit(f"MOV {self.r(pr)}, {self.r(i)}")
            for s in fn.body:
                self.stmt(s)
            self.emit("RET")
            self.emit("")

        self.label("main")
        for s in main:
            self.stmt(s)
        self.emit("HALT")
        return "\n".join(self.output)

    # ── Statements ──

    def stmt(self, s):
        if isinstance(s, VarAssign):
            # Evaluate into variable register directly.
            # expr_to guarantees it won't clobber the target until the end.
            tr = self.alloc(s.name)
            self.expr_to(s.value, tr)

        elif isinstance(s, VarModify):
            tr = self.var(s.name)
            op = s.op[0]  # += -> +
            # left is current value of the var, right is the increment
            # Must evaluate right BEFORE modifying target.
            sr = self.scratch_push()
            self.expr_to(s.value, sr)
            # Now: target has old value, sr has increment
            # Apply op: target = target op sr
            OP = {'+':'ADD','-':'SUB','*':'MUL','/':'DIV','%':'MOD',
                  '&':'AND','|':'OR','^':'XOR','<':'SHL','>':'SHR'}
            self.emit(f"{OP[op]} {self.r(tr)}, {self.r(sr)}")
            self.scratch_pop()

        elif isinstance(s, MemStore):
            # Use PUSH/POP to avoid holding 2 scratch while evaluating sub-exprs
            ar = self.scratch_push()
            self.expr_to(s.addr, ar)
            self.emit(f"PUSH {self.r(ar)}")
            self.scratch_pop()
            vr = self.scratch_push()
            self.expr_to(s.value, vr)
            ar = self.scratch_push()
            self.emit(f"POP {self.r(ar)}")
            self.emit(f"STORE {self.r(ar)}, {self.r(vr)}")
            self.scratch_pop(2)

        elif isinstance(s, IfStmt):
            else_l = self.lbl("else")
            end_l = self.lbl("endif")
            self.branch_false(s.cond, else_l)
            for st in s.body:
                self.stmt(st)
            if s.else_body:
                self.emit(f"JMP {end_l}")
                self.label(else_l)
                for st in s.else_body:
                    self.stmt(st)
                self.label(end_l)
            else:
                self.label(else_l)

        elif isinstance(s, WhileStmt):
            top = self.lbl("while")
            end = self.lbl("endw")
            self.label(top)
            self.branch_false(s.cond, end)
            for st in s.body:
                self.stmt(st)
            self.emit(f"JMP {top}")
            self.label(end)

        elif isinstance(s, FnDef):
            lbl = f"fn_{s.name}"
            self.fn_labels[s.name] = lbl
            self.label(lbl)
            for st in s.body:
                self.stmt(st)
            self.emit("RET")

        elif isinstance(s, ReturnStmt):
            if s.value is not None:
                self.expr_to(s.value, 0)
            self.emit("RET")

        elif isinstance(s, ExprStmt):
            self.expr_discard(s.expr)

    # ── Expressions ──

    def expr_to(self, e, target):
        """Evaluate e into target register.
        
        target is always a var register (r0-r27) or explicitly r0 for returns.
        scratch_push/pop manages r28-r30. These never overlap.
        """
        if isinstance(e, Num):
            self.emit(f"LDI {self.r(target)}, {e.value}")

        elif isinstance(e, Var):
            sr = self.var(e.name)
            if sr != target:
                self.emit(f"MOV {self.r(target)}, {self.r(sr)}")

        elif isinstance(e, BinOp):
            self._binop(e.op, e.left, e.right, target)

        elif isinstance(e, UnOp):
            if e.op == '-':
                self.expr_to(e.right, target)
                self.zero()
                self.emit(f"SUB {self.r(31)}, {self.r(target)}")
                self.emit(f"MOV {self.r(target)}, {self.r(31)}")
            elif e.op == '~':
                self.expr_to(e.right, target)
                self.emit(f"NOT {self.r(target)}")

        elif isinstance(e, IndexExpr):
            sr = self.scratch_push()
            self.expr_to(e.index, sr)
            self.emit(f"LOAD {self.r(target)}, {self.r(sr)}")
            self.scratch_pop()

        elif isinstance(e, Call):
            if not self._builtin(e.name, e.args, target):
                if e.name in self.fn_labels:
                    for i, a in enumerate(e.args):
                        self.expr_to(a, i)
                    self.emit(f"CALL {self.fn_labels[e.name]}")
                    if target != 0:
                        self.emit(f"MOV {self.r(target)}, r0")
                else:
                    raise RuntimeError(f"Unknown function: {e.name}")

    def _binop(self, op, left, right, target):
        """target = left op right.
        
        Evaluates left and right using ONLY the target register as temp,
        PUSHing each to the VM stack immediately. The POP phase uses 2
        scratch registers but only after all recursion returns.
        
        Stack order: PUSH left, PUSH right.
        POP order: first POP = right, second POP = left.
        """
        OP = {'+':'ADD','-':'SUB','*':'MUL','/':'DIV','%':'MOD',
              '&':'AND','|':'OR','^':'XOR','<<':'SHL','>>':'SHR'}
        # Evaluate left into target, PUSH to stack
        self.expr_to(left, target)
        self.emit(f"PUSH {self.r(target)}")
        
        # Evaluate right into target, PUSH to stack
        self.expr_to(right, target)
        self.emit(f"PUSH {self.r(target)}")
        
        # POP: first pop = right (last pushed), second pop = left
        sr = self.scratch_push()    # will hold right (first POP)
        sl = self.scratch_push()    # will hold left (second POP)
        self.emit(f"POP {self.r(sr)}")    # right
        self.emit(f"POP {self.r(sl)}")    # left
        self.emit(f"{OP[op]} {self.r(sl)}, {self.r(sr)}")  # left op= right
        self.emit(f"MOV {self.r(target)}, {self.r(sl)}")
        self.scratch_pop(2)

    def expr_discard(self, e):
        """Evaluate expression, discard result."""
        if isinstance(e, Call):
            if not self._builtin(e.name, e.args, self.SCRATCH_BASE):
                if e.name in self.fn_labels:
                    for i, a in enumerate(e.args):
                        self.expr_to(a, i)
                    self.emit(f"CALL {self.fn_labels[e.name]}")
                else:
                    raise RuntimeError(f"Unknown function: {e.name}")
        else:
            sr = self.scratch_push()
            self.expr_to(e, sr)
            self.scratch_pop()

    def branch_false(self, cond, label):
        """Branch to label if condition is FALSE."""
        if not isinstance(cond, CondExpr):
            sr = self.scratch_push()
            self.expr_to(cond, sr)
            self.zero()
            self.emit(f"BEQ {self.r(sr)}, {self.r(31)}, {label}")
            self.scratch_pop()
            return

        # Use PUSH/POP to avoid holding 2 scratch while evaluating sub-exprs
        sl = self.scratch_push()
        self.expr_to(cond.left, sl)
        self.emit(f"PUSH {self.r(sl)}")
        self.scratch_pop()
        sr = self.scratch_push()
        self.expr_to(cond.right, sr)
        sl = self.scratch_push()
        self.emit(f"POP {self.r(sl)}")

        INV = {'==':'BNE','!=':'BEQ','<':'BGE','>':'BGE','<=':'BLT','>=':'BLT'}
        bop = INV.get(cond.op)
        if not bop:
            raise RuntimeError(f"Unknown comparison: {cond.op}")
        # BLE and BGT don't exist in the assembler, so for > and <= we swap operands
        if cond.op in ('>', '<='):
            self.emit(f"{bop} {self.r(sr)}, {self.r(sl)}, {label}")
        else:
            self.emit(f"{bop} {self.r(sl)}, {self.r(sr)}, {label}")
        self.scratch_pop(2)

    def _builtin(self, name, args, target):
        """Handle builtins. Returns True if handled."""

        # Zero-arg
        ZEROS = {'halt':'HALT','nop':'NOP','yield':'YIELD',
                 'fork':'FORK','send':'SEND','recv':'RECV'}
        if name in ZEROS:
            self.emit(ZEROS[name])
            return True

        # Drawing -- evaluate args one at a time, PUSH each to VM stack, then POP all back
        DRAW = {'pixel':('PSET',3),'pset':('PSET',3),
                'rect':('RECTF',4),'rectf':('RECTF',4),
                'circle':('CIRCLEF',3),'circlef':('CIRCLEF',3),
                'line':('LINE',4)}
        if name in DRAW:
            opname, nargs = DRAW[name]
            if len(args) < nargs:
                raise RuntimeError(f"{name}() needs {nargs} args, got {len(args)}")
            # Evaluate each arg into scratch, PUSH to stack to free scratch for next arg
            for i in range(nargs):
                sr = self.scratch_push()
                self.expr_to(args[i], sr)
                self.emit(f"PUSH {self.r(sr)}")
                self.scratch_pop()
            # POP all args back into scratch registers (LIFO: first POP = last pushed)
            regs = []
            for i in range(nargs):
                sr = self.scratch_push()
                self.emit(f"POP {self.r(sr)}")
                regs.append(sr)
            regs.reverse()  # undo LIFO so regs[0]=arg0, regs[1]=arg1, etc.
            self.emit(f"{opname} {', '.join(self.r(r) for r in regs)}")
            self.scratch_pop(nargs)
            return True

        if name == 'text':
            # Same pattern: evaluate + PUSH, then POP all
            for i in range(3):
                sr = self.scratch_push()
                self.expr_to(args[i], sr)
                self.emit(f"PUSH {self.r(sr)}")
                self.scratch_pop()
            srs = []
            for i in range(3):
                sr = self.scratch_push()
                self.emit(f"POP {self.r(sr)}")
                srs.append(sr)
            srs.reverse()  # undo LIFO
            self.emit(f"TEXT {', '.join(self.r(r) for r in srs)}")
            self.scratch_pop(3)
            return True

        if name == 'spawn':
            s0 = self.scratch_push()
            self.expr_to(args[0], s0)
            self.emit(f"PUSH {self.r(s0)}")
            self.scratch_pop()
            s1 = self.scratch_push()
            if len(args) > 1:
                self.expr_to(args[1], s1)
            else:
                self.emit(f"LDI {self.r(s1)}, 0")
            s0 = self.scratch_push()
            self.emit(f"POP {self.r(s0)}")
            self.emit(f"SPAWN {self.r(s0)}, {self.r(s1)}")
            self.scratch_pop(2)
            return True

        if name == 'push':
            sr = self.scratch_push()
            self.expr_to(args[0], sr)
            self.emit(f"PUSH {self.r(sr)}")
            self.scratch_pop()
            return True

        if name == 'pop':
            self.emit(f"POP {self.r(target)}")
            return True

        return False


