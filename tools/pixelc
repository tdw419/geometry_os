# MAIN
# ═══════════════════════════════════════════════════════════════

def main():
    ap = argparse.ArgumentParser(description="Pixel Compiler for Geometry OS")
    ap.add_argument("input", help="Input .gp file")
    ap.add_argument("-o", "--output", help="Output .asm file")
    args = ap.parse_args()

    with open(args.input) as f:
        source = f.read()

    stmts = parse(source)
    gen = CodeGen()
    gasm = gen.generate(stmts)

    if args.output:
        with open(args.output, "w") as f:
            f.write(gasm + "\n")
        print(f"Wrote {args.output}", file=sys.stderr)
    else:
        print(gasm)

if __name__ == "__main__":
    main()
