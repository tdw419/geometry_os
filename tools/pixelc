def main():
    parser = argparse.ArgumentParser(description="Pixel Compiler for Geometry OS")
    parser.add_argument("input", help="Input .gp file")
    parser.add_argument("-o", "--output", help="Output .gasm file (default: stdout)")
    parser.add_argument("--run", action="store_true", help="Compile, assemble, and run")
    args = parser.parse_args()

    with open(args.input, "r") as f:
        source = f.read()

    tokens = tokenize(source)
    p = Parser(tokens)
    ast = p.parse()

    gen = CodeGen()
    gasm = gen.generate(ast)

    if args.output:
        with open(args.output, "w") as f:
            f.write(gasm + "\n")
        print(f"Wrote {args.output}", file=sys.stderr)
    else:
        print(gasm)

    if args.run:
        import subprocess
        asm_file = args.output or args.input.replace('.gp', '.asm')
        if not args.output:
            with open(asm_file, "w") as f:
                f.write(gasm + "\n")
        # TODO: invoke cargo run with the assembled file
        print("Run mode not yet implemented -- use F8 in the editor to load the .gasm file")

if __name__ == "__main__":
    main()
