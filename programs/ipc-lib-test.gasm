; Test program for lib/ipc.gasm library routines
;
; Tests: ipc_enable, ipc_my_pid, ipc_send_self, ipc_msg_count, ipc_recv
; Forks a child process, sends messages using library calls, child receives.

    JMP test_main

    .include "../lib/ipc.gasm"

test_main:
    ; Enable IPC using library
    CALL ipc_enable

    ; FORK
    FORK
    YIELD

    LDI r10, 0
    BEQ r0, r10, test_child

    ; ── Parent ──
    ; Get child PID
    MOV r7, r0

    ; Send value 100 to child using ipc_send
    MOV r0, r7           ; target PID
    LDI r1, 100          ; value
    CALL ipc_send
    YIELD

    ; Send value 200
    MOV r0, r7
    LDI r1, 200
    CALL ipc_send
    YIELD

    ; Send value 300
    MOV r0, r7
    LDI r1, 300
    CALL ipc_send
    YIELD

    HALT

test_child:
    ; Enable IPC
    CALL ipc_enable

    ; Receive first message
    CALL ipc_wait_recv
    ; Store at 0x2000
    LDI r5, 0x2000
    STORE r5, r0
    YIELD

    ; Receive second message
    CALL ipc_wait_recv
    LDI r5, 0x2001
    STORE r5, r0
    YIELD

    ; Receive third message
    CALL ipc_wait_recv
    LDI r5, 0x2002
    STORE r5, r0
    YIELD

    HALT
