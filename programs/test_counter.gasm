; test_counter.gasm
; Simple program: counts from 0 to 10, stores result at address 5000
; Tests: LDI, ADD, BNE, STORE, HALT
;
; Register allocation:
;   r0 = counter (starts at 0)
;   r1 = increment (1)
;   r2 = limit (10)
;   r3 = store address (5000)

LDI r0, 0        ; counter = 0
LDI r1, 1        ; increment = 1
LDI r2, 10       ; limit = 10
LDI r3, 5000     ; store address

loop:
STORE r3, r0     ; mem[5000 + counter] = counter (approximately)
ADD r0, r1       ; counter++
BNE r0, r2, loop ; if counter != 10, loop back
HALT
