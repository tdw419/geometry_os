# Geometry OS Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control!

# ===========================================
# REQUIRED API KEYS
# ===========================================

# Google Gemini API Key (for AI features)
# Get your key at: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Z.ai API Key (for cognitive agents)
ZAI_API_KEY=your_zai_api_key_here

# ===========================================
# WORDPRESS INTEGRATION (Optional)
# ===========================================

# WordPress site URL
WP_URL=https://your-wordpress-site.com

# WordPress authentication
WP_USERNAME=your_wp_username
WP_PASSWORD=your_wp_password

# ===========================================
# SECURITY SETTINGS
# ===========================================

# API Server authentication key
# Generate with: openssl rand -hex 32
GEOMETRY_OS_API_KEY=your_secure_api_key_here

# Webhook secret (for GitHub webhooks)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ===========================================
# OPTIONAL FEATURES
# ===========================================

# LM Studio model name (for local inference)
LM_STUDIO_LOADED_MODEL=local-model

# Skip track checking (development only)
SKIP_TRACK_CHECK=false

# Clone identification (for distributed mode)
GEOMETRY_OS_IS_CLONE=false
GEOMETRY_OS_CLONE_ID=

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================

# Log level (DEBUG, INFO, WARNING, ERROR)
RUST_LOG=info

# Enable debug features (set to 'false' in production)
DEBUG_MODE=false
