      acceptance_criteria:
      - Disassembler shows ASMSELF with correct operand count
      files:
      - src/vm.rs
    - id: p47.d1.t5
      title: Add ASMSELF to assembler mnemonic list
      status: todo
      description: 'Add "ASMSELF" to the OPCODES list in preprocessor.rs and the assembler in assembler.rs. It takes no operands (just the opcode byte). Update the opcode count in docs and meta.

        '
      dependencies:
      - p47.d1.t1
      acceptance_criteria:
