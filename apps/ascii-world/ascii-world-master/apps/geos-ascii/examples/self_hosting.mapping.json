{
  "name": "GEOS Self-Hosting Compiler",
  "version": "1.0.0",
  "buttons": [
    {
      "label": "A",
      "text": "Edit",
      "action": "JUMP",
      "target": "editor_mode",
      "key": "a"
    },
    {
      "label": "B",
      "text": "Assemble",
      "action": "JUMP",
      "target": "assemble",
      "key": "b"
    },
    {
      "label": "C",
      "text": "Run",
      "action": "JUMP",
      "target": "run_program",
      "key": "c"
    },
    {
      "label": "X",
      "text": "Quit",
      "action": "EXIT",
      "target": "",
      "key": "x"
    }
  ],
  "state_vars": {
    "version": {
      "type": "string",
      "default": "1.0"
    },
    "status": {
      "type": "string",
      "default": "Ready"
    },
    "source_lines": {
      "type": "array",
      "default": [
        "LDI r0, 42",
        "LDI r1, 10",
        "ADD r2, r0, r1",
        "HALT"
      ]
    }
  },
  "memory_layout": {
    "glyph_grid": {
      "base": "0x0000",
      "size": "0x0BFF"
    },
    "sit": {
      "base": "0x0C00",
      "size": "0x00FF"
    },
    "state_buffer": {
      "base": "0x1000",
      "size": "0x03FF"
    },
    "assembler": {
      "base": "0x2000",
      "size": "0x00FF"
    },
    "label_table": {
      "base": "0x2100",
      "size": "0x00FF"
    },
    "emit_buffer": {
      "base": "0x2200",
      "size": "0x0DFF"
    },
    "working_memory": {
      "base": "0x3000",
      "size": "0x0FFF"
    },
    "program_segment": {
      "base": "0x5000",
      "size": "0x2FFF"
    }
  },
  "handlers": {
    "assemble": {
      "action": "SPAWN_VM",
      "address": "0x2000",
      "description": "Spawn assembler VM to compile source"
    },
    "run_program": {
      "action": "SPAWN_VM",
      "address": "0x5000",
      "description": "Spawn execution VM to run compiled code"
    }
  },
  "entry_points": {
    "editor_mode": "0x2000",
    "assemble": "0x2000",
    "run_program": "0x5000"
  }
}
